generator client {
  provider = "prisma-client"
  output   = "../../../apps/web/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  HOMEOWNER
  CONTRACTOR
  ADMIN
}

enum ProjectStatus {
  DRAFT
  OPEN
  IN_REVIEW
  AWARDED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum BidStatus {
  DRAFT
  SUBMITTED
  WITHDRAWN
  SHORTLISTED
  ACCEPTED
  REJECTED
}

enum ContractorApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum PlatformFeedbackCategory {
  BUG
  FEATURE_REQUEST
  ACCOUNT
  BILLING
  PROJECT_ISSUE
  OTHER
}

enum PlatformFeedbackStatus {
  OPEN
  REVIEWED
}

model User {
  id                String             @id @default(uuid())
  email             String             @unique
  passwordHash      String?
  role              UserRole
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  homeownerProfile  HomeownerProfile?
  contractorProfile ContractorProfile?

  projects          Project[]
  bids              Bid[]
  galleryUserPicks  UserGalleryPick[]
  projectContractorMessages ProjectContractorMessage[] @relation("ContractorAuthoredMessages")
  platformFeedback        PlatformFeedback[]
}

model HomeownerProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  fullName  String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ContractorProfile {
  id             String                    @id @default(uuid())
  userId         String                    @unique
  companyName    String
  phone          String?
  licenseNumber  String?
  insuranceDocUrl String?
  serviceZipCodes String[]
  approvalStatus ContractorApprovalStatus  @default(PENDING)
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  user           User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CatalogCategory {
  id          String        @id @default(uuid())
  name        String        @unique
  slug        String        @unique
  createdAt   DateTime      @default(now())

  items       CatalogItem[]
}

model CatalogItem {
  id             String        @id @default(uuid())
  categoryId     String
  name           String
  slug           String        @unique
  description    String?
  unitLabel      String?
  active         Boolean       @default(true)
  optionsSchema  Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  category       CatalogCategory @relation(fields: [categoryId], references: [id])
  projectItems   ProjectItem[]
  galleryImages  GalleryImage[]
}

model Project {
  id            String         @id @default(uuid())
  homeownerId   String
  title         String
  description   String?
  /// Access, timing, constraints — shown to contractors on open projects to cut repeat questions.
  notesForContractors String? @db.Text
  /// Internal coordination / follow-ups (not shown to contractors on the public bid view).
  adminNotes    String?        @db.Text
  zipCode       String
  addressLine1  String?
  city          String?
  state         String?
  status        ProjectStatus  @default(OPEN)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  homeowner     User           @relation(fields: [homeownerId], references: [id])
  items         ProjectItem[]
  bids          Bid[]
  photos        ProjectPhoto[]
  galleryPicks  ProjectGalleryPick[]
  contractorMessages ProjectContractorMessage[]
  platformFeedback   PlatformFeedback[]

  @@index([homeownerId])
  @@index([zipCode])
  @@index([status])
}

/// Homeowner / contractor → admin: bugs, requests, account issues (not bid chat).
model PlatformFeedback {
  id         String                   @id @default(uuid())
  userId     String
  category   PlatformFeedbackCategory   @default(OTHER)
  subject    String?
  body       String                     @db.Text
  projectId  String?
  status     PlatformFeedbackStatus     @default(OPEN)
  createdAt  DateTime                   @default(now())
  reviewedAt DateTime?

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model ProjectItem {
  id             String      @id @default(uuid())
  projectId      String
  catalogItemId  String
  quantity       Int         @default(1)
  selectedOptions Json?
  notes          String?
  createdAt      DateTime    @default(now())

  project        Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  catalogItem    CatalogItem @relation(fields: [catalogItemId], references: [id])
  bidLineItems   BidLineItem[]
  contractorMessages ProjectContractorMessage[]

  @@index([projectId])
  @@index([catalogItemId])
}

/// Question or clarification from a contractor to the homeowner (project-wide or per line item).
model ProjectContractorMessage {
  id             String   @id @default(uuid())
  projectId      String
  contractorId   String
  projectItemId  String?
  body           String   @db.Text
  createdAt      DateTime @default(now())
  readAt         DateTime?

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contractor  User         @relation("ContractorAuthoredMessages", fields: [contractorId], references: [id], onDelete: Cascade)
  projectItem ProjectItem? @relation(fields: [projectItemId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([contractorId])
}

model Bid {
  id             String      @id @default(uuid())
  projectId      String
  contractorId   String
  status         BidStatus   @default(SUBMITTED)
  amount         Decimal     @db.Decimal(12, 2)
  daysToComplete Int
  message        String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  contractor     User        @relation(fields: [contractorId], references: [id])
  project        Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  lineItems      BidLineItem[]

  @@index([projectId])
  @@index([contractorId])
  @@unique([projectId, contractorId])
}

model BidLineItem {
  id            String      @id @default(uuid())
  bidId         String
  projectItemId String
  amount        Decimal     @db.Decimal(12, 2)
  note          String?

  bid           Bid         @relation(fields: [bidId], references: [id], onDelete: Cascade)
  projectItem   ProjectItem @relation(fields: [projectItemId], references: [id], onDelete: Cascade)

  @@unique([bidId, projectItemId])
}

model ProjectPhoto {
  id         String    @id @default(uuid())
  projectId  String
  imageUrl   String
  caption    String?
  sortOrder  Int       @default(0)
  createdAt  DateTime  @default(now())

  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model GalleryImage {
  id            String      @id @default(uuid())
  catalogItemId String?
  imageUrl       String
  title          String?
  caption        String?
  styleTag       String?
  isPublic       Boolean    @default(true)
  createdAt      DateTime   @default(now())

  catalogItem    CatalogItem? @relation(fields: [catalogItemId], references: [id])
  projectPicks   ProjectGalleryPick[]
  userPicks      UserGalleryPick[]

  @@index([catalogItemId])
  @@index([isPublic])
}

model ProjectGalleryPick {
  id            String      @id @default(uuid())
  projectId     String
  galleryImageId String

  /**
   * Searchable keywords for this image in the context of the project.
   * Stored as JSON array of strings, e.g. ["modern", "black", "minimal"].
   */
  keywords      Json

  /**
   * Lower rank means more relevant (1 = top pick).
   */
  rank          Int

  /**
   * Optional explanation returned by AI.
   */
  aiReason      String?

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  project       Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  galleryImage  GalleryImage @relation(fields: [galleryImageId], references: [id], onDelete: Cascade)

  @@unique([projectId, galleryImageId])
  @@index([projectId])
  @@index([galleryImageId])
}

model UserGalleryPick {
  id             String      @id @default(uuid())
  userId         String
  galleryImageId String

  /// Searchable keywords for this image for this user.
  keywords       Json

  /// Lower rank means more relevant (1 = top pick).
  rank           Int

  /// Optional explanation returned by AI.
  aiReason       String?

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  galleryImage   GalleryImage @relation(fields: [galleryImageId], references: [id], onDelete: Cascade)

  @@unique([userId, galleryImageId])
  @@index([userId])
  @@index([galleryImageId])
}