generator client {
  provider = "prisma-client"
  output   = "../../../apps/web/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  HOMEOWNER
  CONTRACTOR
  ADMIN
}

enum ProjectStatus {
  DRAFT
  OPEN
  IN_REVIEW
  AWARDED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum BidStatus {
  DRAFT
  SUBMITTED
  WITHDRAWN
  SHORTLISTED
  ACCEPTED
  REJECTED
}

enum ContractorApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

model User {
  id                String             @id @default(uuid())
  email             String             @unique
  role              UserRole
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  homeownerProfile  HomeownerProfile?
  contractorProfile ContractorProfile?

  projects          Project[]
  bids              Bid[]
}

model HomeownerProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  fullName  String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ContractorProfile {
  id             String                    @id @default(uuid())
  userId         String                    @unique
  companyName    String
  phone          String?
  licenseNumber  String?
  insuranceDocUrl String?
  serviceZipCodes String[]
  approvalStatus ContractorApprovalStatus  @default(PENDING)
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  user           User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CatalogCategory {
  id          String        @id @default(uuid())
  name        String        @unique
  slug        String        @unique
  createdAt   DateTime      @default(now())

  items       CatalogItem[]
}

model CatalogItem {
  id             String        @id @default(uuid())
  categoryId     String
  name           String
  slug           String        @unique
  description    String?
  unitLabel      String?
  active         Boolean       @default(true)
  optionsSchema  Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  category       CatalogCategory @relation(fields: [categoryId], references: [id])
  projectItems   ProjectItem[]
  galleryImages  GalleryImage[]
}

model Project {
  id            String         @id @default(uuid())
  homeownerId   String
  title         String
  description   String?
  zipCode       String
  addressLine1  String?
  city          String?
  state         String?
  status        ProjectStatus  @default(OPEN)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  homeowner     User           @relation(fields: [homeownerId], references: [id])
  items         ProjectItem[]
  bids          Bid[]
  photos        ProjectPhoto[]

  @@index([homeownerId])
  @@index([zipCode])
  @@index([status])
}

model ProjectItem {
  id             String      @id @default(uuid())
  projectId      String
  catalogItemId  String
  quantity       Int         @default(1)
  selectedOptions Json?
  notes          String?
  createdAt      DateTime    @default(now())

  project        Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  catalogItem    CatalogItem @relation(fields: [catalogItemId], references: [id])
  bidLineItems   BidLineItem[]

  @@index([projectId])
  @@index([catalogItemId])
}

model Bid {
  id             String      @id @default(uuid())
  projectId      String
  contractorId   String
  status         BidStatus   @default(SUBMITTED)
  amount         Decimal     @db.Decimal(12, 2)
  daysToComplete Int
  message        String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  contractor     User        @relation(fields: [contractorId], references: [id])
  project        Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  lineItems      BidLineItem[]

  @@index([projectId])
  @@index([contractorId])
  @@unique([projectId, contractorId])
}

model BidLineItem {
  id            String      @id @default(uuid())
  bidId         String
  projectItemId String
  amount        Decimal     @db.Decimal(12, 2)
  note          String?

  bid           Bid         @relation(fields: [bidId], references: [id], onDelete: Cascade)
  projectItem   ProjectItem @relation(fields: [projectItemId], references: [id], onDelete: Cascade)

  @@unique([bidId, projectItemId])
}

model ProjectPhoto {
  id         String    @id @default(uuid())
  projectId  String
  imageUrl   String
  caption    String?
  sortOrder  Int       @default(0)
  createdAt  DateTime  @default(now())

  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model GalleryImage {
  id            String      @id @default(uuid())
  catalogItemId String?
  imageUrl       String
  title          String?
  caption        String?
  styleTag       String?
  isPublic       Boolean    @default(true)
  createdAt      DateTime   @default(now())

  catalogItem    CatalogItem? @relation(fields: [catalogItemId], references: [id])

  @@index([catalogItemId])
  @@index([isPublic])
}